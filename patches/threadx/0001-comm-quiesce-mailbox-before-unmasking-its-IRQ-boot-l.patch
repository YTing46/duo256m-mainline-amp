From b1d7c6456ca8011a8e400ffa811d7dd8a4adac90 Mon Sep 17 00:00:00 2001
From: YTing46 <q36141367@gs.ncku.edu.tw>
Date: Tue, 7 Jul 2026 19:32:03 +0800
Subject: [PATCH 1/7] comm: quiesce mailbox before unmasking its IRQ
 (boot-lottery deafness)

The mailbox interrupt toward the C906L is edge-latched: if a host kick
is already pending (line high) when the firmware initializes -- e.g.
Linux kicked between remoteproc stop and start -- the IRQ init clears
the latched pending while the line stays high, no new edge ever
arrives, and mailbox RX is deaf for the entire boot. Clear the int
latch, enable bits and context slots before request_irq(61) so the
line is guaranteed low and the first real kick makes a fresh edge.

Validated by reproducing the trigger on purpose (stop firmware, kick
while stopped, start): old firmware boots deaf, fixed firmware clears
the pending state at init and pingpong completes 16/16.

Also carries the RT: DBG serial probes (ISR/task/readcb/send) used
during the Bug #2/#3 investigation; to be stripped before latency
measurements.

---
 cvitek/task/comm/src/riscv64/comm_main.c | 35 ++++++++++++++++++++++--
 1 file changed, 33 insertions(+), 2 deletions(-)

diff --git a/cvitek/task/comm/src/riscv64/comm_main.c b/cvitek/task/comm/src/riscv64/comm_main.c
index c6c1dbc..5a44ff7 100755
--- a/cvitek/task/comm/src/riscv64/comm_main.c
+++ b/cvitek/task/comm/src/riscv64/comm_main.c
@@ -40,6 +40,29 @@ void main_cvirtos(void)
 	//arch_usleep(1000 * 1000);
 	printf("create cvi task\n");
 
+	/*
+	 * Quiesce the mailbox BEFORE unmasking its IRQ. The mailbox interrupt
+	 * toward the C906L is effectively edge-latched: if a host kick is
+	 * already pending here (its line already high -- e.g. Linux kicked
+	 * between remoteproc stop and start), our IRQ init clears the latched
+	 * pending while the line stays high, so no new edge ever arrives and
+	 * mailbox RX is dead for the whole boot (boot-lottery deafness).
+	 * Clear the int latch and the context slots so the line is LOW now;
+	 * the first real kick after this makes a fresh edge. Stale kicks
+	 * dropped here are only pre-boot leftovers the host has given up on.
+	 */
+	{
+		volatile struct mailbox_set_register *mr =
+			(struct mailbox_set_register *)MAILBOX_REG_BASE;
+		volatile unsigned long *ctx = (unsigned long *)MAILBOX_REG_BUFF;
+		int i;
+
+		mr->cpu_mbox_set[RECEIVE_CPU].cpu_mbox_int_clr.mbox_int_clr = 0xFF;
+		mr->cpu_mbox_en[RECEIVE_CPU].mbox_info = 0;
+		for (i = 0; i < MAILBOX_MAX_NUM; i++)
+			ctx[i] = 0;
+	}
+
 	/* Start the tasks and timer running. */ // cvitek/driver/common/src/system.c
 	request_irq(MBOX_INT_C906_2ND, prvQueueISR, 0, "mailbox", (void *)0);
 
@@ -225,6 +248,7 @@ static int32_t rpmsg_ept_read_cb(void *payload, uint32_t payload_len, uint32_t s
 		(void)memcpy((void *)&g_msg, payload, payload_len);
         g_remote_addr = src;
         *has_received = 1;
+        printf("RT: DBG readcb DATA=%d src=%d hr=%d\n", g_msg.DATA, (int)src, (int)*has_received);
     }
     return RL_RELEASE;
 }
@@ -267,9 +291,9 @@ void thread_rpmsg_entry(ULONG thread_input)
         {
 			g_has_received = 0;
             g_msg.DATA++;
-			printf("send: %d\n",g_msg.DATA);
-            (void)rpmsg_lite_send(gp_rpmsg_dev_inst, gp_rpmsg_ept, g_remote_addr, (char *)&g_msg, sizeof(THE_MESSAGE),
+            int32_t sret = rpmsg_lite_send(gp_rpmsg_dev_inst, gp_rpmsg_ept, g_remote_addr, (char *)&g_msg, sizeof(THE_MESSAGE),
                                   RL_DONT_BLOCK);
+			printf("send: %d ret=%d\n",g_msg.DATA, sret);
         }
 		if (1 == led_has_recieved)
         {
@@ -305,11 +329,17 @@ void prvCmdQuRunTask(ULONG thread_input)
 		//xQueueReceive(gTaskCtx[0].queHandle, &rtos_cmdq, portMAX_DELAY);
 		tx_queue_receive(&mailbox_queue, &rtos_cmdq, TX_WAIT_FOREVER);
 
+		printf("RT: DBG task cmd_id=%d param=0x%x lv=%d\n",
+		       rtos_cmdq.cmd_id, rtos_cmdq.param_ptr,
+		       rtos_cmdq.resv.valid.linux_valid);
+
 		switch (rtos_cmdq.cmd_id) {
 		case 0 :
+			printf("RT: DBG env_isr(0)\n");
 			env_isr(0);
 			break;
 		case 1 :
+			printf("RT: DBG env_isr(1)\n");
 			env_isr(1);
 			break;
 		case CMD_TEST_A:
@@ -370,6 +400,7 @@ void prvQueueISR(void)
 	set_val = mbox_reg->cpu_mbox_set[RECEIVE_CPU].cpu_mbox_int_int.mbox_int;
 
 	if (set_val) {
+		printf("RT: DBG ISR set=0x%x\n", set_val);
 		for (i = 0; i < MAILBOX_MAX_NUM; i++) {
 			valid_val = set_val & (1 << i);
 
