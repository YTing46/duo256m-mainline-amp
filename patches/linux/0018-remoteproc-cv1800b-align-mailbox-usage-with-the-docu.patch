From 5dd848e6804c24d8f1952d86697e673ce2b57fb9 Mon Sep 17 00:00:00 2001
From: YTing46 <q36141367@gs.ncku.edu.tw>
Date: Tue, 14 Jul 2026 23:22:18 +0800
Subject: [PATCH 18/24] remoteproc: cv1800b: align mailbox usage with the
 documented binding

The binding already specifies two channels named tx/rx; use a single
kick channel with the vq index in the payload instead of the ad-hoc
vq0/vq1/rx triple, add the missing MAILBOX dependency, and document
the SEC_SYS syscon (with its required eFuse clock) as a dedicated
binding since the generic syscon schema does not admit clocks.

Also spell out the enable-register RMW race with remote CPUs in the
mailbox driver (no per-bit set/clear in hardware; a lost remote set
self-heals on the next send).

---
 .../soc/sophgo/sophgo,cv1800b-sec-sys.yaml    | 54 +++++++++++++++++++
 .../boot/dts/sophgo/sg2002-milkv-duo256m.dts  |  4 +-
 drivers/mailbox/cv1800-mailbox.c              |  7 +++
 drivers/remoteproc/Kconfig                    |  1 +
 drivers/remoteproc/sophgo_cv1800b_c906l.c     | 35 ++++++------
 5 files changed, 79 insertions(+), 22 deletions(-)
 create mode 100644 Documentation/devicetree/bindings/soc/sophgo/sophgo,cv1800b-sec-sys.yaml

diff --git a/Documentation/devicetree/bindings/soc/sophgo/sophgo,cv1800b-sec-sys.yaml b/Documentation/devicetree/bindings/soc/sophgo/sophgo,cv1800b-sec-sys.yaml
new file mode 100644
index 000000000000..4f2b170badda
--- /dev/null
+++ b/Documentation/devicetree/bindings/soc/sophgo/sophgo,cv1800b-sec-sys.yaml
@@ -0,0 +1,54 @@
+# SPDX-License-Identifier: (GPL-2.0 OR BSD-2-Clause)
+%YAML 1.2
+---
+$id: http://devicetree.org/schemas/soc/sophgo/sophgo,cv1800b-sec-sys.yaml#
+$schema: http://devicetree.org/meta-schemas/core.yaml#
+
+title: Sophgo CV18XX/SG200X SoC security subsystem controller
+
+maintainers:
+  - Yu-Ting Tseng <q36141367@gs.ncku.edu.tw>
+
+description:
+  The Sophgo CV18XX/SG200X security subsystem (SEC_SYS) register block
+  carries, among others, the C906L remote processor enable and boot
+  address registers. Bus access to the block is gated by the eFuse
+  clock; with that clock disabled, any access stalls the SoC
+  interconnect. The clock is therefore a required property so it is
+  enabled around register accesses instead of relying on
+  clk_ignore_unused.
+
+properties:
+  compatible:
+    items:
+      - enum:
+          - sophgo,cv1800b-sec-sys
+          - sophgo,sg2000-sec-sys
+          - sophgo,sg2002-sec-sys
+      - const: syscon
+
+  reg:
+    maxItems: 1
+
+  clocks:
+    maxItems: 1
+    description: eFuse clock gating bus access to the block (CLK_EFUSE)
+
+required:
+  - compatible
+  - reg
+  - clocks
+
+additionalProperties: false
+
+examples:
+  - |
+    #include <dt-bindings/clock/sophgo,cv1800.h>
+
+    syscon@20b0000 {
+      compatible = "sophgo,sg2002-sec-sys", "syscon";
+      reg = <0x020b0000 0x1000>;
+      clocks = <&clk CLK_EFUSE>;
+    };
+
+...
diff --git a/arch/riscv/boot/dts/sophgo/sg2002-milkv-duo256m.dts b/arch/riscv/boot/dts/sophgo/sg2002-milkv-duo256m.dts
index 160556f703ea..cfb7b3304419 100644
--- a/arch/riscv/boot/dts/sophgo/sg2002-milkv-duo256m.dts
+++ b/arch/riscv/boot/dts/sophgo/sg2002-milkv-duo256m.dts
@@ -98,8 +98,8 @@ rproc {
 		memory-region = <&rtos_reserved>, <&vdev0vring0>, <&vdev0vring1>;
 		resets = <&rst RST_CPUSYS2>;
 		sophgo,syscon = <&sec_sys>;
-		mboxes = <&mailbox 0 2>, <&mailbox 1 2>, <&mailbox 7 1>;
-		mbox-names = "vq0", "vq1", "rx";
+		mboxes = <&mailbox 0 2>, <&mailbox 7 1>;
+		mbox-names = "tx", "rx";
 		dma-noncoherent;
 	};
 };
diff --git a/drivers/mailbox/cv1800-mailbox.c b/drivers/mailbox/cv1800-mailbox.c
index b62200a0166d..fb6b79781415 100644
--- a/drivers/mailbox/cv1800-mailbox.c
+++ b/drivers/mailbox/cv1800-mailbox.c
@@ -99,6 +99,13 @@ static irqreturn_t cv1800_mbox_irq(int irq, void *dev_id)
 			 * on their bit to clear (tx-done) then hang, and the
 			 * shared SET register re-raises our own interrupt for
 			 * channels this CPU transmits on.
+			 *
+			 * The read-modify-write can race a remote CPU setting
+			 * its own bit in this register (the hardware has no
+			 * per-bit set/clear). A lost remote set delays that
+			 * message until the remote's next send re-raises it;
+			 * serializing would need the SoC's hardware spinlocks,
+			 * which mainline does not model.
 			 */
 			en = readb(mbox->mbox_base + MBOX_EN_REG(RECV_CPU));
 			writeb(en & ~valid, mbox->mbox_base +
diff --git a/drivers/remoteproc/Kconfig b/drivers/remoteproc/Kconfig
index a104faff1dac..66698d753a5d 100644
--- a/drivers/remoteproc/Kconfig
+++ b/drivers/remoteproc/Kconfig
@@ -310,6 +310,7 @@ config RCAR_REMOTEPROC
 config SOPHGO_CV1800B_C906L
 	tristate "Sophgo CV1800B C906L remoteproc support"
 	depends on ARCH_SOPHGO || COMPILE_TEST
+	depends on MAILBOX
 	help
 	  Say y here to support CV1800B C906L remote processor via the remote
 	  processor framework.
diff --git a/drivers/remoteproc/sophgo_cv1800b_c906l.c b/drivers/remoteproc/sophgo_cv1800b_c906l.c
index c643148193fe..429080741ef5 100644
--- a/drivers/remoteproc/sophgo_cv1800b_c906l.c
+++ b/drivers/remoteproc/sophgo_cv1800b_c906l.c
@@ -39,10 +39,10 @@
  * @rproc: the remote processor handle
  * @syscon: regmap for accessing security system registers
  * @client: mailbox client (kicks in both directions)
- * @tx_ch: per-virtqueue kick channels toward the C906L
+ * @tx_ch: kick channel toward the C906L (vq index rides in the payload)
  * @rx_ch: channel the firmware kicks us back on
- * @kick_msg: persistent kick payloads (the mailbox framework queues the
- *            message pointer, so it must outlive the mbox_send_message call)
+ * @kick_msg: persistent per-vq kick payloads (the mailbox framework queues
+ *            the message pointer, so it must outlive mbox_send_message)
  */
 struct cv1800b_c906l {
 	struct device *dev;
@@ -50,7 +50,7 @@ struct cv1800b_c906l {
 	struct rproc *rproc;
 	struct regmap *syscon;
 	struct mbox_client client;
-	struct mbox_chan *tx_ch[CV1800B_C906L_NUM_VQS];
+	struct mbox_chan *tx_ch;
 	struct mbox_chan *rx_ch;
 	u64 kick_msg[CV1800B_C906L_NUM_VQS];
 };
@@ -182,10 +182,10 @@ static void cv1800b_c906l_kick(struct rproc *rproc, int vqid)
 	struct cv1800b_c906l *priv = rproc->priv;
 	int ret;
 
-	if (vqid < 0 || vqid >= CV1800B_C906L_NUM_VQS || !priv->tx_ch[vqid])
+	if (vqid < 0 || vqid >= CV1800B_C906L_NUM_VQS || !priv->tx_ch)
 		return;
 
-	ret = mbox_send_message(priv->tx_ch[vqid], &priv->kick_msg[vqid]);
+	ret = mbox_send_message(priv->tx_ch, &priv->kick_msg[vqid]);
 	if (ret < 0)
 		dev_err(priv->dev, "kick vq%d failed: %d\n", vqid, ret);
 }
@@ -222,11 +222,9 @@ static const struct rproc_ops cv1800b_c906l_ops = {
 static void cv1800b_c906l_free_mboxes(void *data)
 {
 	struct cv1800b_c906l *priv = data;
-	int i;
 
-	for (i = 0; i < CV1800B_C906L_NUM_VQS; i++)
-		if (priv->tx_ch[i])
-			mbox_free_channel(priv->tx_ch[i]);
+	if (priv->tx_ch)
+		mbox_free_channel(priv->tx_ch);
 	if (priv->rx_ch)
 		mbox_free_channel(priv->rx_ch);
 }
@@ -238,9 +236,6 @@ static void cv1800b_c906l_free_mboxes(void *data)
  */
 static int cv1800b_c906l_request_mboxes(struct cv1800b_c906l *priv)
 {
-	static const char * const tx_names[CV1800B_C906L_NUM_VQS] = {
-		"vq0", "vq1"
-	};
 	struct mbox_chan *chan;
 	int i;
 
@@ -248,13 +243,13 @@ static int cv1800b_c906l_request_mboxes(struct cv1800b_c906l *priv)
 	priv->client.tx_block = false;
 	priv->client.rx_callback = cv1800b_c906l_mbox_rx;
 
-	for (i = 0; i < CV1800B_C906L_NUM_VQS; i++) {
+	for (i = 0; i < CV1800B_C906L_NUM_VQS; i++)
 		priv->kick_msg[i] = CV1800B_C906L_KICK_MSG(i);
-		chan = mbox_request_channel_byname(&priv->client, tx_names[i]);
-		if (IS_ERR(chan))
-			goto err;
-		priv->tx_ch[i] = chan;
-	}
+
+	chan = mbox_request_channel_byname(&priv->client, "tx");
+	if (IS_ERR(chan))
+		goto err;
+	priv->tx_ch = chan;
 
 	chan = mbox_request_channel_byname(&priv->client, "rx");
 	if (IS_ERR(chan))
@@ -266,7 +261,7 @@ static int cv1800b_c906l_request_mboxes(struct cv1800b_c906l *priv)
 
 err:
 	cv1800b_c906l_free_mboxes(priv);
-	priv->tx_ch[0] = priv->tx_ch[1] = NULL;
+	priv->tx_ch = NULL;
 	priv->rx_ch = NULL;
 
 	if (PTR_ERR(chan) == -EPROBE_DEFER)
